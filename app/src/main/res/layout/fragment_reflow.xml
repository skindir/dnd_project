<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3E4C9"
    android:fillViewport="true"
    tools:context=".ui.reflow.ReflowFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spell_screen_padding">

        <TextView
            android:id="@+id/text_spellbook_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/spellbook_title"
            android:textAppearance="?attr/textAppearanceHeadline6"
            android:textColor="#241D18" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_add_spell"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/add_spell_title" />

        <LinearLayout
            android:id="@+id/spell_levels_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
