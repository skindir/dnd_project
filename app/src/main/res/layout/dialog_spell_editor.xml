<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:minHeight="520dp"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/text_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:textColor="#2A211C"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <TextView
                style="@style/SpellDialogLabel"
                android:text="@string/spell_name_label" />

            <EditText
                android:id="@+id/edit_spell_name"
                style="@style/SpellDialogEditText"
                android:hint="@string/spell_name_hint"
                android:inputType="textCapWords"
                android:maxLines="1" />

            <TextView
                style="@style/SpellDialogLabel"
                android:text="@string/spell_level_label" />

            <EditText
                android:id="@+id/edit_spell_level"
                style="@style/SpellDialogEditText"
                android:hint="@string/spell_level_hint"
                android:inputType="number"
                android:maxLines="1" />

            <TextView
                style="@style/SpellDialogLabel"
                android:text="@string/spell_class_label" />

            <EditText
                android:id="@+id/edit_spell_class"
                style="@style/SpellDialogEditText"
                android:hint="@string/spell_class_hint"
                android:inputType="textCapWords"
                android:maxLines="1" />

            <TextView
                style="@style/SpellDialogLabel"
                android:text="@string/spell_range_label" />

            <EditText
                android:id="@+id/edit_spell_range"
                style="@style/SpellDialogEditText"
                android:hint="@string/spell_range_hint"
                android:inputType="text"
                android:maxLines="1" />

            <TextView
                style="@style/SpellDialogLabel"
                android:text="@string/spell_attack_type_label" />

            <EditText
                android:id="@+id/edit_spell_attack_type"
                style="@style/SpellDialogEditText"
                android:hint="@string/spell_attack_type_hint"
                android:inputType="textCapSentences"
                android:maxLines="1" />

            <TextView
                style="@style/SpellDialogLabel"
                android:text="@string/spell_damage_type_label" />

            <EditText
                android:id="@+id/edit_spell_damage_type"
                style="@style/SpellDialogEditText"
                android:hint="@string/spell_damage_type_hint"
                android:inputType="textCapWords"
                android:maxLines="1" />

            <TextView
                style="@style/SpellDialogLabel"
                android:text="@string/spell_damage_label" />

            <EditText
                android:id="@+id/edit_spell_damage"
                style="@style/SpellDialogEditText"
                android:hint="@string/spell_damage_hint"
                android:inputType="textCapCharacters"
                android:maxLines="1" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_cancel"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@android:string/cancel"
            android:textAllCaps="true" />

        <Button
            android:id="@+id/button_save"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/add_spell_action"
            android:textAllCaps="true" />
    </LinearLayout>
</LinearLayout>
